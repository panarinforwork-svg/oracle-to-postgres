 "            , 1 AS is_prac"
 "            , 0 AS is_ga"
 "            "
 "            , ws.max_sem AS last_sem"
 "          from"
 "            (select distinct"
 "               nsem"
 "               , max(nsem) over (partition by id_curriculum"
 "                                              , war_start) AS max_sem"
