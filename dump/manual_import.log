 "from   semestr sm"
 "join   curriculum c on c.id = sm.id_curriculum"
 "join   usp u on u.id = sm.id_usp"
 "join   vw$disc_cycle dc on dc.ID = u.id_disc_cycle"
 "join   vw$study_period_lines spl on spl.id_study_period = c.id_study_period"
 "                                and spl.nsem = sm.nsem"
 "where  sm.id_curriculum =  sys_context('curriculum_ctx','curr_id')"
 "group by sm.id_usp,sm.id_curriculum"
 ") t"
