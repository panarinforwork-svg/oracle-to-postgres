 "  procedure create_curr_set(in_fk_curriculum in number"
 "                            , in_lect_decr in number default 0.9)"
 "  as"
 "  begin"
 "    for i in(select t.nsem"
 "             from"
 "               (select level*2 - 1 AS nsem"
 "                from dual"
 "                connect by level < 5"
 "               ) t"
 "             where not exists (select 1"
 "                               from war_semestr ws"
 "                               where"
 "                                 ws.id_curriculum = in_fk_curriculum"
 "                                 and ws.war_start = t.nsem))"
 "    loop"
 "      create_curr(v_fk_curriculum => in_fk_curriculum"
 "                  , v_lect_decr => nvl(in_lect_decr, 0.9)"
 "                  , v_war_start => i.nsem);"
 "    end loop;"
 "  end create_curr_set;"
 ""
 "  -- ???????? ?????????? ? ?????. ????? ?????????? ?? ?????????."
 "  function get_for_war(in_id_curr in number) return sys_refcursor"
 "  as"
 "    ret_cur sys_refcursor;"
 "  begin"
 "  "
 "    curr_spec_pkg.set_getting_diff_rows(0);"
 "    "
 "    open ret_cur for"
 "       select"
 "         t.id_curriculum"
 "         , t.okso_keys"
 "         , t.name_okso"
 "         , t.nsem"
 "         , t.study_weeks AS weeks"
 "         /*, decode(t.is_ga"
 "                  , 1"
 "                  , t.weeks"
 "                  , null) ga_weeks*/"
 "         ,  case when t.is_ga = 1"
 "                      or t.is_prac = 1"
 "                 then t.weeks end AS ga_weeks"
 "         , t.ord_num"
 "         , t.ord_num1"
 "         , t.ord_num2"
 "         , t.id_disc"
 "         , t.name_disc"
 "           || decode(t.is_ga"
 "                        , 1"
 "                        , '   ' || t.weeks || ' ??????'"
 "                        , '') AS name_disc"
 "         , t.hours"
 "         ,   2 * nvl(floor(t.lect * t.weeks / 2), 0)"
 "           + 2 * nvl(floor(t.prac * t.weeks / 2), 0)"
 "           + 2 * nvl(floor(t.labs * t.weeks / 2), 0) AS aud_hours"
 "         , greatest(0"
 "                    , t.hours - 2 * nvl(floor(t.lect * t.weeks / 2), 0)"
 "                              - 2 * nvl(floor(t.prac * t.weeks / 2), 0)"
 "                              - 2 * nvl(floor(t.labs * t.weeks / 2), 0)"
 "                              - t.sess_hours"
 "                   ) AS self_study"
 "         , 2 * floor(t.lect * t.weeks / 2) AS lect"
 "         , 2 * floor(t.prac * t.weeks / 2) AS prac"
 "         , 2 * floor(t.labs * t.weeks / 2) AS labs"
 "         , t.sess_hours"
 "         , case when t.project > 0"
 "                then 1"
 "                else null"
 "                end AS project         "
 "         , t.vid_otch"
 "         , t.protocol_numb"
 "         , t.protocol_date"
 "         "
 "         "
 "       from"
 "          "
 "         (select distinct"
 "            c.id id_curriculum"
 "            , o.okso_key || '.' || o.okso_key2 AS okso_keys"
 "            , o.direction AS name_okso"
 "            , sm.nsem"
 "            , u.ord_num1"
 "              || nvl2(u.ord_num2, '.', '')"
 "              || u.ord_num2 AS ord_num"
 "            , u.ord_num1"
 "            , u.ord_num2"
 "            , d.id AS id_disc"
 "            , d.name AS name_disc"
 "            , dc.is_ga"
 "            , dc.is_prac"
 "            , dc.is_fiz"
 "            , nvl(sm.hours, 0) AS hours"
 "            , sm.lect"
 "            , sm.prac"
 "            , sm.labs"
 "            , nvl(sm.sess_hours, 0) AS sess_hours"
 "            , nvl(sm.kursp, 0)"
 "              + nvl(sm.kursr, 0)"
 "              + nvl(sm.kr, 0)"
 "              + nvl(sm.rgz, 0) AS project              "
 "            , coalesce(to_number(decode(sm.weeks, 0, null, sm.weeks))"
 "                       , case when dc.is_prac = 1 "
 "                                   and sm.is_distrib = 0"
 "                                then spl.PRACTICE_WEEKS"
 "                              when dc.is_ga = 1"
 "                                then nvl(spl.VKR_WEEKS, 0)"
 "                                     + nvl(spl.DEFENCE_WEEKS, 0)"
 "                                     + nvl(spl.GE_WEEKS, 0)"
 "                              else spl.study_weeks"
 "                              end"
 "                      ) AS weeks"
 "            , coalesce(to_number(decode(sm.weeks, 0, null, sm.weeks))"
 "                       , spl.study_weeks) AS study_weeks"
 "            , case when sm.ekzamen = 1"
 "                     then '???.'"
 "                   when sm.zachet = 1"
 "                     then '???.'"
 "                   when sm.zachet = 2"
 "                     then '???. ???.'"
 "                   end AS vid_otch"
 "            , cp.protocol_numb"
 "            , cp.protocol_date"
 "            "
 "          from"
 "            curriculum c"
 "            join okso o on o.id = c.id_okso"
 "            join study_period sp on sp.id = c.id_study_period"
 "            join vw$study_period_lines spl on spl.id_study_period = c.id_st"
 "udy_period"
 "            join usp u on u.id_curriculum = c.id"
 "            join semestr sm on sm.id_usp = u.id"
 "                               and sm.nsem = spl.nsem"
 "            join disc d on d.id = u.id_disc"
 "            join vw$disc_cycle dc on dc.id = u.id_disc_cycle"
 "            left join curriculum_protocol cp on /*cp.id_facultet = c.fsk_fa"
 "cultet"
 "                                                and cp.year = c.year_enrol*"
 "/"
 "                                                cp.id = c.id_curriculum_pro"
 "tocol"
 "            "
 "            "
 "          where"
 "            c.id = in_id_curr"
 "         ) t"
 "       order by"
 "         nsem"
 "         , ord_num1"
 "         , ord_num2;"
 "       "
 "       "
 "       "
 "          "
 "          "
 "    return ret_cur;"
 "  end get_for_war;"
 ""
 "  procedure set_id_curr_to_ctx(in_id_curr in number)"
 "  as"
 "  begin"
 "    dbms_session.set_context('war_ctx','id_curriculum',in_id_curr);"
 "  end set_id_curr_to_ctx;"
 ""
 "begin"
 "  null;"
 "end war_currs;"
