 "            "
 "            , 0 AS lect"
 "            , 0 AS prac"
 "            , 0 AS labs"
 "            , 0 AS total"
 "            , '?????? ???' AS vid_otch"
 "            "
 "            , 0 AS hpw"
 "            , 0 AS diff"
 "            , 0 AS ht"
 "            , 0 AS wht"
 "            , 2 AS weeks"
 "            , ws.war_start "
 "            , 0 AS is_fiz"
 "            , 0 AS is_prac"
 "            , 1 AS is_ga"
 "            "
 "            , ws.max_sem AS last_sem"
 "          from"
 "            (select distinct"
 "               nsem"
