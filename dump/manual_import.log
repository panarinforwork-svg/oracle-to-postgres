 "--for_test_pkg.short_log('ccurr_visualization_pkg.get_disc_fullname: in_nse"
 "m='||in_nsem);"
 "    select"
 "      t.id_usp"
 "      , t.ord_num1"
 "      , t.ord_num2"
 "      , t.id_disc_cycle"
 "    into"
 "      v_id_usp"
 "      , v_ord_num1"
 "      , v_ord_num2"
 "      , v_id_disc_cycle"
 "    from"
 "      (select"
 "         u.id id_usp"
 "         , u.ord_num1"
 "         , u.ord_num2"
 "         , u.id_disc_cycle"
 "         , u.disc_colour"
 "       from"
 "         vw$usp_for_visualization u"
 "       where u.id_curriculum = in_fk_curriculum"
 "      ) t"
 "    where t.disc_colour = in_disc_colour;"
 "    "
 "    open ret_cur for"
 "          select"
 "            u.id id_usp"
 "            , u.id_disc"
 "            , nvl(dc.code_plan || '.', '') "
 "              || u.ord_num1"
 "              || nvl('.' || u.ord_num2, '')"
 "              || ' '"
 "              || d.name fullname"
 "            , d.name dname"
 "            , u.ord_num1"
 "            , dc.code_plan cycle"
 "            , u.ord_num2 ord_num2"
 "          from"
 "            usp u"
 "            join disc d on d.id = u.id_disc"
 "            join semestr s on s.id_usp = u.id"
 "                              and s.nsem = in_nsem"
 "            left join disc_cycle dc on dc.id = u.id_disc_cycle"
 "          where"
 "               u.id = v_id_usp"
 "            or (    u.id_curriculum          = in_fk_curriculum"
 "                and nvl(u.ord_num1, -1)      = nvl(v_ord_num1, -1)"
 "                and nvl(u.ord_num2, -1)      = nvl(v_ord_num2, -1)"
 "                and nvl(u.id_disc_cycle, -1) = nvl(v_id_disc_cycle, -1))"
 "          order by"
 "            fullname;"
 "    "
 "--for_test_pkg.log('ccurr_visualization_pkg', 'get_disc_fullname', 'F');"
 "    return ret_cur;"
 "  end get_disc_fullname;"
 ""
