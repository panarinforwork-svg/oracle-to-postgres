 "procedure set_usp_know(v_is_sel in number,"
 "                       v_id_usp in number,"
 "                       v_id_know_skill in number,"
 "                       v_id_curriculum in number)"
 "as"
 "   v_id_comp_model number;"
 "begin"
 "   "
 "   v_id_comp_model := get_model_by_usp(v_id_usp);"
 "   "
 "   if v_is_sel = 1 then"
 "      insert into usp_know(id_curriculum,id_usp,id_know_skill)"
 "      select v_id_curriculum,v_id_usp,v_id_know_skill"
 "      from dual"
 "      where not exists ("
 "           select 1 from usp_know uk"
 "           where uk.id_curriculum = v_id_curriculum"
 "           and   uk.id_usp = v_id_usp"
 "           and   uk.id_know_skill = v_id_know_skill"
 "      );"
 "      "
 "      insert into usp_comp(id_curriculum,id_usp,id_competence)"
 "      select  v_id_curriculum,v_id_usp,cks.id_competence"
 "      from    competence_know_skill cks"
 "      where   cks.id_know_skill =  v_id_know_skill"
 "      and     cks.id_comp_model = v_id_comp_model"
 "      and not exists ("
 "          select 1"
 "          from usp_comp uc"
 "          where uc.id_curriculum = v_id_curriculum"
 "            and uc.id_usp = v_id_usp"
 "            and uc.id_competence = cks.id_competence "
 "      );"
 "   else"
 "     delete from usp_know uk"
 "     where uk.id_curriculum = v_id_curriculum"
 "       and uk.id_usp = v_id_usp"
 "       and uk.id_know_skill = v_id_know_skill;"
 "       "
 "     delete from usp_comp uc"
 "     where uc.id_curriculum = v_id_curriculum"
 "     and   uc.id_usp = v_id_usp"
 "     and   not exists ("
 "         select 1"
 "         from competence_know_skill cks"
 "         join usp_know uk on uk.id_know_skill = cks.id_know_skill"
 "         where cks.id_comp_model = v_id_comp_model"
 "           and uk.id_usp = v_id_usp"
 "           and cks.id_competence = uc.id_competence"
 "     );  "
 "   end if;"
 "   "
 "   commit;"
 "end;"
 ""
