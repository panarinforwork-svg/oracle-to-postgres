 "  function get_disc_fullname(in_fk_curriculum in number"
 "                             , in_disc_colour in number"
 "                             , in_nsem in number) return sys_refcursor"
 "  as"
 "    ret_cur sys_refcursor;"
 "    v_id_usp number;"
 "    v_ord_num1 number;"
 "    v_ord_num2 number;"
 "    v_id_disc_cycle number;"
 "  begin"
 "    "
 "--for_test_pkg.log('ccurr_visualization_pkg', 'get_disc_fullname', 'S');"
 "--for_test_pkg.short_log('ccurr_visualization_pkg.get_disc_fullname: in_fk_"
 "curriculum='||in_fk_curriculum);"
 "--for_test_pkg.short_log('ccurr_visualization_pkg.get_disc_fullname: in_dis"
